---
import Base from '../../layouts/Base.astro';
import ProjectEntry from '../../components/ProjectEntry.astro';
import { projects } from '../../data/projects';

const course = projects.find((p) => p.slug === 'fundaciones-escritura-futbol');

const roles = [
  {
    title: 'Instructor of Record · Teaching Assistant',
    place: 'University of Iowa',
    period: 'Aug 2025 — Present',
    body: 'Intermediate Spanish I (Spring 2026) and Elementary Spanish II (Fall 2025): I design the lessons, lead every session, and handle assessment for communicative, student-centered language courses.',
  },
  {
    title: 'Language & Culture Assistant · NALCAP',
    place: 'Bermeo, Basque Country, Spain',
    period: 'Oct 2022 — Jun 2023',
    body: 'A cultural ambassador in a public primary school in Bermeo, a storied Basque fishing village. The school ran largely in Basque (Euskara), a language and culture all its own, as I taught American English to children aged 7–12.',
  },
  {
    title: 'English Teacher',
    place: 'English Connections, Madrid',
    period: 'Sep 2023 — May 2024',
    body: 'Prepared primary and secondary students for Cambridge certification (A2–C1) and led a weekly adult conversation class on culture and current events.',
  },
  {
    title: 'English Teacher',
    place: 'IMAGINE English Learning Center, Bermeo',
    period: 'Oct 2022 — Jun 2023',
    body: 'Designed and delivered English conversation classes for students aged 7–16.',
  },
];

const games = [
  {
    title: 'Brotes · Módulo 2',
    kind: 'Jeopardy review game',
    href: '/games/brotes-modulo-2-jeopardy.html',
  },
];
---

<Base
  title="Teaching"
  description="How Gregory Johnson Jr. teaches — a teaching philosophy, a prospective Spanish course, and the lesson materials he builds, plus where he has taught."
>
  <section class="page container">
    <header class="page__head reveal">
      <h1 class="page__title">Teaching</h1>
      <p class="page__intro measure">
        How I teach, a course I designed, and the materials I build.
      </p>
    </header>

    <section class="philosophy-card reveal" aria-label="Teaching philosophy">
      <p class="philosophy-card__kind">Teaching philosophy</p>
      <p class="philosophy-card__excerpt">
        &ldquo;A classroom should be a place where every student feels challenged and comfortable at
        the same time.&rdquo;
      </p>
      <p class="philosophy-card__note measure">
        A full statement of how I teach.
      </p>
      <a class="arrow-link" href="/teaching/philosophy/">
        Read my teaching philosophy <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </section>

    {
      course && (
        <section class="course reveal" style="--reveal-delay: 80ms" aria-label="A course I designed">
          <h2 class="block__heading">A course I designed</h2>
          <p class="block__lead measure">
            A prospective Spanish course, built around football.
          </p>
          <div class="work-list">
            <ProjectEntry project={course} />
          </div>
        </section>
      )
    }

    <section class="materials reveal" aria-label="Classroom materials">
      <h2 class="block__heading">Materials I build</h2>
      <p class="block__lead measure">
        Working with Claude, I build lesson-by-lesson packets that companion our OER textbooks, like
        <em>Brotes</em>. The review games are part of that. Here is one you can play.
      </p>
      <ul class="materials__games">
        {
          games.map((g) => (
            <li class="game-card">
              <div class="game-card__text">
                <p class="game-card__kind">{g.kind}</p>
                <h3 class="game-card__title">{g.title}</h3>
              </div>
              <a class="button button--ghost" href={g.href} target="_blank" rel="noopener">
                Play the game <span class="arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="roles reveal" aria-label="Teaching roles">
      <h2 class="block__heading">Where I&rsquo;ve taught</h2>
      <ol class="roles__list">
        {
          roles.map((role) => (
            <li class="role">
              <div class="role__meta">
                <p class="role__period">{role.period}</p>
              </div>
              <div class="role__content">
                <h3 class="role__title">{role.title}</h3>
                <p class="role__place">{role.place}</p>
                <p class="role__body">{role.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <div class="teaching-cta reveal">
      <a class="button" href="/#contact">
        Talk teaching with me <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
      <a class="arrow-link" href="/teaching/philosophy/">
        Read my teaching philosophy <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .page {
    padding-block: var(--space-xl) var(--space-lg);
  }
  .page__head {
    margin-bottom: var(--space-xl);
  }
  .page__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
  }
  .page__intro {
    margin-top: var(--space-sm);
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.5;
  }

  .block__heading {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }
  .block__lead {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: var(--space-lg);
  }

  /* Teaching philosophy feature */
  .philosophy-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: var(--space-2xl);
  }
  .philosophy-card__kind {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
  }
  .philosophy-card__excerpt {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.25;
    color: var(--ink-strong);
    margin-top: var(--space-sm);
    max-width: 28ch;
  }
  .philosophy-card__note {
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    color: var(--muted);
  }

  .course {
    margin-bottom: var(--space-2xl);
  }
  .work-list {
    border-bottom: 1px solid var(--line);
  }

  /* Materials */
  .materials {
    margin-bottom: var(--space-2xl);
  }
  .materials__games {
    display: grid;
    gap: var(--space-sm);
  }
  .game-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding: var(--space-md) var(--space-lg);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .game-card__kind {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
  }
  .game-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink-strong);
    margin-top: 0.15rem;
  }

  /* Roles */
  .roles {
    margin-bottom: var(--space-2xl);
  }
  .role {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--line);
  }
  .role:last-child {
    border-bottom: 1px solid var(--line);
  }
  .role__period {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
    padding-top: 0.2rem;
  }
  .role__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink-strong);
  }
  .role__place {
    margin-top: 0.15rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--green);
  }
  .role__body {
    margin-top: var(--space-sm);
    font-family: var(--font-serif);
    line-height: 1.6;
    color: var(--ink);
    max-width: 58ch;
  }

  .teaching-cta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    max-width: var(--measure);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }

  @media (max-width: 38rem) {
    .role {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>
