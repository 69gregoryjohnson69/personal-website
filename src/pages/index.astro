---
import Base from '../layouts/Base.astro';
import Portrait from '../components/Portrait.astro';
import ProjectEntry from '../components/ProjectEntry.astro';
import { featuredProjects } from '../data/projects';
import { essays, formatDate } from '../lib/essays';

const courses = [
  { name: 'Intermediate Spanish I', term: 'Spring 2026' },
  { name: 'Elementary Spanish II', term: 'Fall 2025' },
];
const latestEssays = essays.slice(0, 2);
---

<Base title="Gregory Johnson Jr.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <h1 class="hero__name reveal">Gregory Johnson Jr.</h1>
        <p class="hero__lead reveal" style="--reveal-delay: 90ms">
          I love sports and economics, and literature is my avenue for critical analysis. I&rsquo;m a
          humanities scholar, an applied AI researcher, and a Spanish language educator at the
          University of Iowa.
        </p>
        <div class="hero__actions reveal" style="--reveal-delay: 210ms">
          <a class="button" href="/personal-website/projects/">
            Explore the work <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a class="arrow-link hero__secondary" href="/personal-website/teaching/">
            How I teach <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
      <div class="hero__portrait reveal" style="--reveal-delay: 160ms">
        <Portrait alt="Gregory Johnson Jr." />
      </div>
    </div>
  </section>

  <!-- Featured work -->
  <section class="section container">
    <div class="section__head reveal">
      <div>
        <h2 class="section__title">Selected work</h2>
        <p class="section__intro">
          Course design and public-humanities research.
        </p>
      </div>
      <a class="arrow-link section__all" href="/personal-website/projects/">
        All work <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <div class="work-list">
      {
        featuredProjects.map((project, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 90}ms`}>
            <ProjectEntry project={project} />
          </div>
        ))
      }
    </div>
  </section>

  <!-- Writing -->
  <section class="section container">
    <div class="section__head reveal">
      <div>
        <h2 class="section__title">Writing</h2>
        <p class="section__intro">
          Reading culture as a commons.
        </p>
      </div>
      <a class="arrow-link section__all" href="/personal-website/writing/">
        All writing <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
    <ul class="writing-list">
      {
        latestEssays.map((essay, i) => (
          <li class="writing-row reveal" style={`--reveal-delay: ${i * 90}ms`}>
            <a class="writing-row__link" href={essay.url}>
              {essay.kind && <span class="writing-row__kind">{essay.kind}</span>}
              <h3 class="writing-row__title" lang={essay.lang}>{essay.title}</h3>
              <p class="writing-row__dek" lang={essay.lang}>{essay.dek}</p>
              <p class="writing-row__meta">
                <time datetime={essay.date}>{formatDate(essay.date)}</time>
                {essay.readingTime && <span> &middot; {essay.readingTime} read</span>}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Teaching -->
  <section class="section section--warm">
    <div class="container teaching">
      <div class="teaching__lead reveal">
        <h2 class="section__title">Teaching</h2>
        <p class="teaching__body">
          I want a classroom where students feel challenged and comfortable at once. Most of the real
          learning happens out loud.
        </p>
        <a class="arrow-link" href="/personal-website/teaching/">
          More on teaching <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="teaching__courses reveal" style="--reveal-delay: 100ms">
        <p class="teaching__label">Recently in the classroom</p>
        <ul>
          {
            courses.map((c) => (
              <li class="teaching__course">
                <span class="teaching__course-name">{c.name}</span>
                <span class="teaching__course-term">{c.term}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ---- Hero ---- */
  .hero {
    padding-block: clamp(3.5rem, 9vw, 7rem) var(--space-2xl);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.45fr 0.75fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .hero__name {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 1.9rem + 3.6vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
  }
  .hero__role {
    margin-top: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--green);
  }
  .hero__lead {
    margin-top: var(--space-md);
    max-width: 54ch;
    color: var(--ink);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
  }
  .hero__portrait {
    max-width: 320px;
    width: 100%;
    margin-inline: auto;
  }

  /* ---- Section scaffolding ---- */
  .section {
    padding-block: var(--space-2xl);
  }
  .section--warm {
    background:
      linear-gradient(180deg, transparent, var(--coral-wash) 50%, transparent),
      var(--bg);
  }
  .section__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }
  .section__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
  }
  .section__intro {
    margin-top: var(--space-xs);
    max-width: 54ch;
    color: var(--muted);
  }
  .section__all {
    white-space: nowrap;
    padding-bottom: 0.35rem;
  }

  /* ---- Work list ---- */
  .work-list {
    border-bottom: 1px solid var(--line);
  }

  /* ---- Writing list ---- */
  .writing-list {
    border-bottom: 1px solid var(--line);
  }
  .writing-row {
    border-top: 1px solid var(--line);
  }
  .writing-row__link {
    display: block;
    padding: var(--space-lg) 0;
    transition: padding-inline var(--dur) var(--ease-out);
  }
  .writing-row__kind {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: var(--space-2xs);
  }
  .writing-row__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--ink-strong);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .writing-row__dek {
    margin-top: var(--space-2xs);
    max-width: 62ch;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink);
  }
  .writing-row__meta {
    margin-top: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  @media (hover: hover) {
    .writing-row__link:hover {
      padding-inline: var(--space-md);
    }
    .writing-row__link:hover .writing-row__title {
      color: var(--green);
    }
  }

  /* ---- Teaching ---- */
  .teaching {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }
  .teaching__body {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    max-width: 58ch;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--ink);
  }
  .teaching__label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-sm);
  }
  .teaching__course {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--line);
  }
  .teaching__course:last-child {
    border-bottom: 1px solid var(--line);
  }
  .teaching__course-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink-strong);
  }
  .teaching__course-term {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  /* ---- About card ---- */
  .about-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.75rem, 4vw, 3rem);
  }
  .about-card__body {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
    max-width: 64ch;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--ink);
  }

  /* ---- Responsive ---- */
  @media (max-width: 52rem) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__portrait {
      grid-row: 1;
      max-width: 240px;
      margin-inline: 0;
    }
    .hero__copy {
      grid-row: 2;
    }
    .section__head {
      align-items: flex-start;
    }
    .teaching {
      grid-template-columns: 1fr;
    }
  }
</style>

