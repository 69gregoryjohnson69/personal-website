---
import Base from './Base.astro';
import { formatDate } from '../lib/essays';

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.dek}>
  <article class="essay" lang={frontmatter.lang}>
    <header class="essay__header">
      <a class="essay__back" href="/personal-website/writing/">
        <span class="arrow" aria-hidden="true">&larr;</span> Writing
      </a>
      {frontmatter.kind && <p class="essay__kind reveal">{frontmatter.kind}</p>}
      <h1 class="essay__title reveal" style="--reveal-delay: 60ms">{frontmatter.title}</h1>
      <p class="essay__dek reveal" style="--reveal-delay: 110ms">{frontmatter.dek}</p>
      <p class="essay__meta reveal" style="--reveal-delay: 160ms">
        <time datetime={frontmatter.date}>{formatDate(frontmatter.date)}</time>
        {frontmatter.readingTime && <span> &middot; {frontmatter.readingTime} read</span>}
      </p>
    </header>
    <div class="essay__body prose">
      <slot />
    </div>
    <footer class="essay__footer">
      <a class="arrow-link" href="/personal-website/writing/">
        <span class="arrow" aria-hidden="true">&larr;</span> More writing
      </a>
    </footer>
  </article>
</Base>

<style>
  .essay {
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2rem);
    padding-block: var(--space-xl) var(--space-lg);
  }
  .essay__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .essay__back .arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .essay__back:hover {
    color: var(--ink);
  }
  .essay__back:hover .arrow {
    transform: translateX(-3px);
  }
  .essay__kind {
    margin-top: var(--space-lg);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
  }
  .essay__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: 1.16;
    margin-top: var(--space-sm);
  }
  .essay__dek {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--muted);
    margin-top: var(--space-md);
    max-width: 52ch;
  }
  .essay__meta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
    margin-top: var(--space-md);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--line);
  }
  .essay__body {
    margin-top: var(--space-lg);
  }
  .essay__footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }
  .essay__footer .arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .essay__footer .arrow-link:hover .arrow {
    transform: translateX(-3px);
  }
</style>

