---
import type { Project } from '../data/projects';
interface Props {
  project: Project;
}
const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<article class="entry" data-accent={project.accent}>
  <a class="entry__link" href={`${base}projects/${project.slug}/`} aria-labelledby={`p-${project.slug}`}>
    <div class="entry__head">
      <h3 class="entry__name" id={`p-${project.slug}`}>{project.title}</h3>
      <span class="entry__kind">{project.kind}</span>
    </div>
    <p class="entry__tagline">{project.tagline}</p>
    <div class="entry__foot">
      <ul class="entry__tags">
        {project.tags.map((t) => <li>{t}</li>)}
      </ul>
      <span class="entry__more">
        <span class="entry__year">{project.year}</span>
        <span class="entry__cta">
          Read more <span class="arrow" aria-hidden="true">&rarr;</span>
        </span>
      </span>
    </div>
  </a>
</article>

<style>
  .entry {
    border-top: 1px solid var(--line);
  }
  .entry__link {
    display: block;
    padding: var(--space-lg) 0;
    transition: padding-inline var(--dur) var(--ease-out);
  }
  .entry__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .entry__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--ink-strong);
    max-width: 26ch;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .entry__kind {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--muted);
    padding: 0.15rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .entry__tagline {
    margin-top: var(--space-xs);
    max-width: 64ch;
    color: var(--ink);
    font-size: var(--text-lg);
    line-height: 1.45;
  }
  .entry__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
  .entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--muted);
  }
  .entry__tags li {
    padding: 0.18rem 0.55rem;
    background: var(--surface);
    border-radius: 6px;
  }
  .entry__more {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }
  .entry__year {
    color: var(--muted);
  }
  .entry__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    color: var(--accent-color);
    white-space: nowrap;
  }
  .entry__cta .arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .entry[data-accent='cobalt'] {
    --accent-color: var(--cobalt);
  }
  .entry[data-accent='coral'] {
    --accent-color: var(--coral);
  }

  @media (hover: hover) {
    .entry__link:hover {
      padding-inline: var(--space-md);
    }
    .entry__link:hover .entry__name {
      color: var(--accent-color);
    }
    .entry__link:hover .entry__cta .arrow {
      transform: translateX(4px);
    }
  }
  .entry__link:focus-visible {
    outline-offset: -2px;
  }
</style>

